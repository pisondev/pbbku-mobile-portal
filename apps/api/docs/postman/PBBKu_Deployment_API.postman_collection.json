  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const requestName = pm.info.requestName;",
          "const isAdminGuard = requestName.indexOf('Admin guard') === 0;",
          "const isNegative = requestName.indexOf('Negative -') === 0;",
          "const url = pm.request.url.toString();",
          "const isRpc = url.indexOf('/api/rpc/') >= 0;",
          "",
          "pm.test('Response time is under 5000ms', function () {",
          "  pm.expect(pm.response.responseTime).to.be.below(5000);",
          "});",
          "",
          "pm.test('Security headers are present', function () {",
          "  pm.expect(pm.response.headers.get('X-Content-Type-Options')).to.eql('nosniff');",
          "  pm.expect(pm.response.headers.get('X-Frame-Options')).to.eql('DENY');",
          "});",
          "",
          "if (!isAdminGuard && !isNegative) {",
          "  pm.test('Status code is 2xx', function () {",
          "    pm.expect(pm.response.code).to.be.within(200, 299);",
          "  });",
          "}",
          "",
          "if (isAdminGuard) {",
          "  pm.test('Write endpoint rejects request without admin key', function () {",
          "    pm.expect([401, 403]).to.include(pm.response.code);",
          "  });",
          "}",
          "",
          "if (!isNegative) {",
          "  pm.test('Response body is JSON when present', function () {",
          "    const text = pm.response.text();",
          "    if (text && text.trim().length > 0) {",
          "      pm.response.to.have.jsonBody();",
          "    }",
          "  });",
          "}",
          "",
          "if (!isAdminGuard && !isNegative && isRpc) {",
          "  pm.test('RPC response uses json wrapper', function () {",
          "    const body = pm.response.json();",
          "    pm.expect(body).to.have.property('json');",
          "  });",
          "}",
          "",
          "if (!isAdminGuard && !isNegative) {",
          "  pm.test('Successful payload is not an error envelope', function () {",
          "    const text = pm.response.text();",
          "    if (text && text.trim().length > 0) {",
          "      const body = pm.response.json();",
          "      pm.expect(body).to.not.have.property('error');",
          "    }",
          "  });",
          "}",
          "",
          "if (!isAdminGuard && !isNegative && isRpc) {",
          "  pm.test('RPC payload key exists even when value is empty', function () {",
          "    const body = pm.response.json();",
          "    pm.expect(Object.prototype.hasOwnProperty.call(body, 'json')).to.eql(true);",
          "  });",
          "}",
          "",
          "if (!isAdminGuard && !isNegative && requestName.indexOf('GET /health') === 0) {",
          "  pm.test('Health service is ok', function () {",
          "    const body = pm.response.json();",
          "    pm.expect(body.status).to.eql('ok');",
          "    pm.expect(body.service).to.eql('pbbku-internal-api');",
          "  });",
          "}"
        ]
      }
    }
  ]
}
