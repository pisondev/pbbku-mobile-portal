    {
      "name": "08 - Admin Write Guard",
      "description": "Endpoint write tetap didokumentasikan, tetapi request ini sengaja mengetes bahwa deployment menolak write tanpa admin key.",
      "item": [
        {
          "name": "Admin guard - POST /api/rpc/objekPajak/save should reject without key",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Write endpoint rejects request without admin key', function () {",
                  "  pm.expect([401, 403]).to.include(pm.response.code);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
